rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email in ['rajeshkpallywear@gmail.com', 'ceo@pallywear.com', 'stalingm.mano@gmail.com'] ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function hasUserRole(roles) {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserRole() in roles;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\\\-]+$');
    }

    // Users Collection
    match /users/{userId} {
      function isValidUser(data) {
        return data.keys().hasAll(['id', 'email', 'role', 'name', 'createdAt']) &&
               data.id is string &&
               data.email is string &&
               data.role in ['admin', 'staff', 'accounts', 'order_management', 'production', 'delivery', 'marketing', 'user', 'designer', 'digitizer', 'telecaller'] &&
               data.name is string &&
               data.createdAt is string;
      }

      function isAdminRoleEligible(email) {
        return email == 'ceo@pallywear.com' || 
               email == 'rajeshkpallywear@gmail.com' || 
               email == 'stalingm.mano@gmail.com' || 
               email.matches('(?i)^admin.*') || 
               email.matches('(?i)^ceo.*');
      }

      function isStaff() {
        return isSignedIn() && (
          hasUserRole(['staff', 'admin', 'designer', 'accounts', 'order_management', 'production', 'delivery', 'marketing', 'digitizer', 'telecaller']) ||
          isAdmin() ||
          request.auth.token.email.matches('(?i)^staff.*')
        );
      }

      allow get: if isOwner(userId) || isAdmin() || isStaff();
      allow list: if isSignedIn() && (isAdmin() || isStaff());
      
      allow create: if isOwner(userId) && isValidUser(request.resource.data) && 
                      (isAdminRoleEligible(request.resource.data.email) ? request.resource.data.role == 'admin' : true);
      
      allow update: if isOwner(userId) && 
                      (
                        // Allow own field updates except role usually
                        (request.resource.data.role == resource.data.role && request.resource.data.email == resource.data.email) ||
                        isAdmin() ||
                        (isAdminRoleEligible(request.resource.data.email) && request.resource.data.role == 'admin')
                      );
      
      allow delete: if isAdmin();
    }

    // Test Connection
    match /test/connection {
      allow read: if true;
    }

    // Leads Collection
    match /leads/{leadId} {
      function isValidLead(data) {
        return data.keys().hasAll(['id', 'name', 'leadType', 'createdBy', 'entryDate']) &&
               data.id is string &&
               data.name is string &&
               data.leadType in ['Hot', 'Warm', 'Cold'];
      }

      function canReadLeads() {
        return isSignedIn() && (
          resource.data.createdBy == request.auth.uid || 
          isAdmin() || 
          hasUserRole(['admin', 'marketing', 'user', 'staff', 'accounts', 'order_management', 'digitizer', 'telecaller'])
        );
      }

      allow get, list: if canReadLeads();
      
      // Telecallers can create leads assigned to any user (round-robin)
      // Regular users create only their own leads
      allow create: if isSignedIn() && isValidId(leadId) && isValidLead(request.resource.data) && (
        hasUserRole(['telecaller']) ||
        request.resource.data.createdBy == request.auth.uid
      );
      
      allow update: if isSignedIn() && (resource.data.createdBy == request.auth.uid || isAdmin() || hasUserRole(['marketing', 'admin', 'telecaller'])) && 
                      isValidLead(request.resource.data) &&
                      request.resource.data.createdBy == resource.data.createdBy;
                      
      allow delete: if isSignedIn() && (resource.data.createdBy == request.auth.uid || isAdmin());
    }

    // Invoices Collection
    match /invoices/{invoiceId} {
      function isValidInvoice(data) {
        return data.keys().hasAll(['id', 'invoiceNumber', 'total', 'createdBy', 'createdAt']) &&
               data.id is string &&
               data.invoiceNumber is string &&
               data.total is number &&
               data.createdBy is string;
      }

      function canReadInvoices() {
        return isSignedIn() && (
          resource.data.createdBy == request.auth.uid || 
          isAdmin() || 
          hasUserRole(['admin', 'accounts', 'order_management', 'staff', 'digitizer'])
        );
      }

      allow get, list: if canReadInvoices();
      allow create: if isSignedIn() && (request.resource.data.id == invoiceId) && isValidInvoice(request.resource.data);
      allow update: if isSignedIn() && (resource.data.createdBy == request.auth.uid || isAdmin() || hasUserRole(['accounts', 'admin'])) && 
                      isValidInvoice(request.resource.data) &&
                      request.resource.data.createdBy == resource.data.createdBy;
      allow delete: if isSignedIn() && (resource.data.createdBy == request.auth.uid || isAdmin());
    }

    // Orders Collection
    match /orders/{orderId} {
      function isValidOrder(data) {
        return data.keys().hasAll(['id', 'status', 'createdBy', 'createdAt']) &&
               data.id is string &&
               data.status is string &&
               data.createdBy is string;
      }

      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && isValidId(orderId) && isValidOrder(request.resource.data) && request.resource.data.createdBy == request.auth.uid;
      allow update: if isSignedIn();
      allow delete: if isSignedIn() && (resource.data.createdBy == request.auth.uid || isAdmin());
    }

    // App Settings
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin() || hasUserRole(['admin', 'telecaller', 'staff', 'order_management']);
    }

    // Attachments Collection
    match /attachments/{attachmentId} {
      allow read, write: if isSignedIn();
    }

    // Inventory Collection
    match /inventory/{itemId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (
        isAdmin() ||
        hasUserRole(['admin', 'order_management'])
      );
    }

    // Leaves Collection - Open access to support local mock and Firebase authentication operations
    match /leaves/{leaveId} {
      allow read, write: if true;
    }

    // Login Logs Collection - Open access to save user GPS and agent data upon login
    match /pallywear_login_logs/{logId} {
      allow read, write: if true;
    }

    // Advanced Chat Collections
    match /pallywear_adv_chats/{chatId} {
      allow read, write: if true;
    }

    match /pallywear_adv_invites/{inviteId} {
      allow read, write: if true;
    }

    match /pallywear_adv_messages/{messageId} {
      allow read, write: if true;
    }

    // Call Logs Collection - Telecallers can read/write their own call logs
    match /call_logs/{logId} {
      allow read: if isSignedIn() && (
        isAdmin() ||
        hasUserRole(['admin', 'telecaller', 'staff', 'order_management'])
      );
      allow create: if isSignedIn() && hasUserRole(['telecaller', 'admin', 'staff']);
      allow update: if isSignedIn() && (resource.data.agentId == request.auth.uid || isAdmin());
      allow delete: if isSignedIn() && (resource.data.agentId == request.auth.uid || isAdmin());
    }
  }
}
